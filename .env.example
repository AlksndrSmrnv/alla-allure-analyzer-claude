ALLURE_ENDPOINT=https://your-allure-instance.example.com
ALLURE_TOKEN=your-api-token-here
ALLURE_PROJECT_ID=1

# --- Core HTTP settings ---
# ALLURE_REQUEST_TIMEOUT=30
# ALLURE_PAGE_SIZE=100
# ALLURE_MAX_PAGES=50
# ALLURE_DETAIL_CONCURRENCY=10
# ALLURE_LOG_LEVEL=INFO
# ALLURE_SSL_VERIFY=true

# --- Clustering ---
# ALLURE_CLUSTERING_THRESHOLD=0.60
# ALLURE_LOGS_CONCURRENCY=5
# ALLURE_LOGS_CLUSTERING_WEIGHT=0.0

# --- Knowledge base / feedback ---
# ALLURE_KB_POSTGRES_DSN=postgresql://user:pass@localhost:5432/alla_kb
# ALLURE_KB_MIN_SCORE=0.15
# ALLURE_KB_MAX_RESULTS=5
# ALLURE_FEEDBACK_SERVER_URL=http://alla.company.com:8090

# --- LLM (Langflow) ---
# ALLURE_LANGFLOW_BASE_URL=http://langflow.company.com
# ALLURE_LANGFLOW_FLOW_ID=your-flow-id-here
# ALLURE_LANGFLOW_API_KEY=your-langflow-api-key
# ALLURE_LLM_TIMEOUT=120
# ALLURE_LLM_CONCURRENCY=3
# ALLURE_LLM_MAX_RETRIES=3
# ALLURE_LLM_RETRY_BASE_DELAY=1.0

# --- HTML reports / links ---
# ALLURE_REPORT_URL=http://jenkins/job/alla/33/artifact/alla-report.html
# ALLURE_REPORT_LINK_NAME=[Alla] HTML-отчёт запуска автотестов
# ALLURE_REPORTS_DIR=/data/reports
# ALLURE_SERVER_EXTERNAL_URL=https://alla.company.com

# --- alla-server ---
# ALLURE_SERVER_HOST=0.0.0.0
# ALLURE_SERVER_PORT=8090

# --- secman / Vault ---
# ALLURE_SECMAN_ADDR=https://secman.company.com
# ALLURE_SECMAN_NAMESPACE=
# ALLURE_SECMAN_K8S_ROLE=alla-role
# ALLURE_SECMAN_K8S_JWT_PATH=/var/run/secrets/kubernetes.io/serviceaccount/token
# ALLURE_SECMAN_KV_VERSION=v2
# ALLURE_SECMAN_MOUNT_POINT=secret
# ALLURE_SECMAN_SECRET_PATH=alla/prod
