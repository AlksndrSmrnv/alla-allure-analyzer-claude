# --- Required ---
ALLURE_ENDPOINT=https://your-allure-instance.example.com
ALLURE_TOKEN=your-api-token-here
# Optional: used as a default scope for --launch-name / launch resolve.
# ALLURE_PROJECT_ID=1
# --- Vault Proxy (optional, for Kubernetes) ---
# If set, ALLURE_TOKEN, ALLURE_KB_POSTGRES_DSN, ALLURE_GIGACHAT_CERT_B64
# and ALLURE_GIGACHAT_KEY_B64 are loaded from Vault with fallback to env vars.
# ALLURE_VAULT_URL=http://vault-proxy/v1/secret/data/alla

# --- Common runtime settings ---
ALLURE_LOG_LEVEL=INFO
ALLURE_SSL_VERIFY=true
# ALLURE_REQUEST_TIMEOUT=30
# ALLURE_PAGE_SIZE=100
# ALLURE_MAX_PAGES=50
# ALLURE_DETAIL_CONCURRENCY=10

# --- Clustering and attachment log extraction ---
# Lower threshold merges more aggressively; higher threshold splits more.
# ALLURE_CLUSTERING_THRESHOLD=0.60
# ALLURE_LOGS_CONCURRENCY=5
# ALLURE_LOGS_CLUSTERING_WEIGHT=0.15

# --- PostgreSQL knowledge base / feedback / merge rules / dashboard ---
# PostgreSQL is the only current knowledge-base backend.
# When this DSN is set, knowledge-base search, feedback memory, KB creation,
# merge rules and dashboard storage are enabled.
# ALLURE_KB_POSTGRES_DSN=postgresql://user:pass@localhost:5432/alla_kb
# ALLURE_KB_MIN_SCORE=0.15
# ALLURE_KB_MAX_RESULTS=5

# URL of a running alla-server used by interactive controls inside HTML reports:
# create/update knowledge entries, feedback, merge rules. If empty, those
# controls are hidden.
# ALLURE_FEEDBACK_SERVER_URL=https://alla.company.com

# --- GigaChat LLM analysis ---
# LLM is enabled automatically when base URL, client cert and private key are set.
# ALLURE_GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
# ALLURE_GIGACHAT_CERT_B64=<base64-encoded cert.pem>
# ALLURE_GIGACHAT_KEY_B64=<base64-encoded private.key>
# ALLURE_GIGACHAT_MODEL=GigaChat-2-Max
# ALLURE_LLM_TIMEOUT=120
# ALLURE_LLM_CONCURRENCY=3
# ALLURE_LLM_REQUEST_DELAY=0.5
# ALLURE_LLM_MAX_RETRIES=3
# ALLURE_LLM_RETRY_BASE_DELAY=1.0
# ALLURE_LLM_PROMPT_MESSAGE_MAX_CHARS=2000
# ALLURE_LLM_PROMPT_TRACE_MAX_CHARS=400
# ALLURE_LLM_PROMPT_LOG_MAX_CHARS=8000

# --- Writing comments and report links to TestOps ---
# Set false for dry/read-only server usage.
# ALLURE_PUSH_TO_TESTOPS=true

# Static report URL, commonly used when Jenkins stores the generated artifact.
# ALLURE_REPORT_URL=http://jenkins/job/alla/33/artifact/alla-report.html
# ALLURE_REPORT_LINK_NAME=[Alla] HTML-отчёт запуска автотестов

# --- Self-hosted reports ---
# alla-server can save HTML reports to a directory and serve them from /reports.
# With SERVER_EXTERNAL_URL set, generated links look like:
#   https://alla.company.com/reports/<filename>.html
# ALLURE_REPORTS_DIR=/data/reports
# ALLURE_SERVER_EXTERNAL_URL=https://alla.company.com

# Store generated reports in PostgreSQL table alla.report instead of, or in
# addition to, filesystem storage. Requires ALLURE_KB_POSTGRES_DSN.
# ALLURE_REPORTS_POSTGRES=false

# --- HTTP server ---
# ALLURE_SERVER_HOST=0.0.0.0
# ALLURE_SERVER_PORT=8090
