# --- Vault Proxy (опционально, для Kubernetes) ---
# Если задан — секреты ALLURE_TOKEN, ALLURE_KB_POSTGRES_DSN,
# ALLURE_GIGACHAT_CERT_B64 и ALLURE_GIGACHAT_KEY_B64
# загружаются из Vault с fallback на env vars ниже.
# ALLURE_VAULT_URL=http://vault-proxy/v1/secret/data/alla

ALLURE_ENDPOINT=https://your-allure-instance.example.com
ALLURE_TOKEN=your-api-token-here
ALLURE_PROJECT_ID=1
ALLURE_LOG_LEVEL=INFO
ALLURE_SSL_VERIFY=true
# ALLURE_CLUSTERING_ENABLED=true
# ALLURE_CLUSTERING_THRESHOLD=0.60
# ALLURE_KB_ENABLED=false
# ALLURE_KB_BACKEND=yaml
# ALLURE_KB_PATH=knowledge_base
# ALLURE_KB_POSTGRES_DSN=postgresql://user:pass@localhost:5432/alla_kb
# ALLURE_KB_MIN_SCORE=0.15
# ALLURE_KB_MAX_RESULTS=3
# ALLURE_KB_PUSH_ENABLED=false
# --- LLM (GigaChat) ---
# ALLURE_GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
# ALLURE_GIGACHAT_CERT_B64=<base64-encoded cert.pem>
# ALLURE_GIGACHAT_KEY_B64=<base64-encoded private.key>
# ALLURE_GIGACHAT_MODEL=GigaChat-2-Max
# ALLURE_LLM_TIMEOUT=120
# ALLURE_LLM_CONCURRENCY=3
# ALLURE_LLM_REQUEST_DELAY=0.5
# --- HTML-отчёт ---
# ALLURE_REPORT_URL=http://jenkins/job/alla/33/artifact/alla-report.html
# ALLURE_REPORT_LINK_NAME=[Alla] HTML-отчёт запуска автотестов
# --- Self-hosted отчёты (alla-server раздаёт отчёты вместо Jenkins) ---
# ALLURE_REPORTS_DIR=/data/reports
# ALLURE_SERVER_EXTERNAL_URL=https://alla.company.com
