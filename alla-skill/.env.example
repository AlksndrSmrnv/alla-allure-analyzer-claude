# --- TestOps (обязательно) ---
ALLURE_ENDPOINT=https://allure.example.com
ALLURE_TOKEN=
ALLURE_PROJECT_ID=1

# --- PostgreSQL (обязательно для pipeline/serve.py: skill_run, отчёты и server-side KB) ---
ALLURE_KB_POSTGRES_DSN=postgresql://user:pass@localhost:5432/alla_kb

# --- Push в TestOps ---
# Комментарии к тест-кейсам (LLM/KB) выключены по умолчанию — скрипт
# push_to_testops.py всё равно требует --confirm, но фоновый дефолт
# оставлен false на случай альтернативных consumers.
ALLURE_PUSH_COMMENTS=false
# Прикрепление ссылки на HTML-отчёт к запуску по умолчанию включено.
# ALLURE_PUSH_REPORT_LINK=true

# --- Отчёты ---
ALLURE_REPORTS_DIR=./reports
ALLURE_REPORT_URL=
ALLURE_REPORT_LINK_NAME=[Alla] HTML-отчёт

# URL alla-server, который HTML и REST CLI дёргают для KB-кнопок («Создать
# решение для кластера»), like/dislike и merge rules. Браузер и CLI не пишут
# в PostgreSQL напрямую — нужна REST-прослойка. Для local-first запусти
#   python alla-skill/scripts/serve.py
# в отдельном терминале и поставь обе переменные ниже на http://127.0.0.1:8090.
# Если оставить пустым — отчёт сгенерируется, но без интерактивных кнопок
# (только текст + статичные KB-совпадения).
ALLURE_FEEDBACK_SERVER_URL=

# Публичный URL сервера для ссылок /reports/<file> и кнопки «Перезапустить
# анализ». При локальной работе через serve.py — то же значение, что и
# ALLURE_FEEDBACK_SERVER_URL (например, http://127.0.0.1:8090).
ALLURE_SERVER_EXTERNAL_URL=

# --- Тонкие настройки (опц.) ---
ALLURE_CLUSTERING_THRESHOLD=0.60
ALLURE_LOGS_CLUSTERING_WEIGHT=0.15
ALLURE_KB_MIN_SCORE=0.15
ALLURE_KB_MAX_RESULTS=5
ALLURE_LOGS_CONCURRENCY=5
ALLURE_DETAIL_CONCURRENCY=10
ALLURE_REQUEST_TIMEOUT=30
ALLURE_PAGE_SIZE=100
ALLURE_SSL_VERIFY=true
ALLURE_LOG_LEVEL=INFO

# --- Vault Proxy (опц.) ---
# Если задан, ALLURE_TOKEN и ALLURE_KB_POSTGRES_DSN можно загружать
# из Vault, оставив их пустыми в .env.
# ALLURE_VAULT_URL=
