# --- TestOps (обязательно) ---
ALLURE_ENDPOINT=https://allure.example.com
ALLURE_TOKEN=
ALLURE_PROJECT_ID=1

# --- alla-server (обязательно для pipeline) ---
# Скилл-скрипты делают TestOps-триаж локально (этим токеном), а всю работу
# с PostgreSQL (skill_run, KB lookup, merge rules, отчёты) делегируют
# alla-server. DSN базы знаний живёт ТОЛЬКО на сервере — в этом .env его нет.
#
# Укажи базовый URL alla-server. Для local-first запусти в отдельном
# терминале `python alla-skill/scripts/serve.py` (сервер прочитает DSN из
# своего окружения) и поставь переменную ниже на http://127.0.0.1:8090.
ALLURE_FEEDBACK_SERVER_URL=http://127.0.0.1:8090

# --- Push в TestOps ---
# Комментарии к тест-кейсам (LLM/KB) выключены по умолчанию — скрипт
# push_to_testops.py всё равно требует --confirm.
ALLURE_PUSH_COMMENTS=false
# Прикрепление ссылки на HTML-отчёт к запуску по умолчанию включено.
# ALLURE_PUSH_REPORT_LINK=true

# --- Отчёты ---
# HTML рендерит и сохраняет в alla.report сам сервер; публичный URL отчёта
# (/reports/<file>) тоже резолвит сервер из своего ALLURE_SERVER_EXTERNAL_URL.
# Эта переменная нужна, только если хочешь ДОПОЛНИТЕЛЬНО класть копию HTML
# на локальный диск пользователя.
ALLURE_REPORTS_DIR=

# --- Тонкие настройки кластеризации (опц.) ---
# Кластеризация выполняется локально, поэтому пороги читаются здесь.
ALLURE_CLUSTERING_THRESHOLD=0.60
ALLURE_LOGS_CLUSTERING_WEIGHT=0.15
ALLURE_LOGS_CONCURRENCY=5
ALLURE_DETAIL_CONCURRENCY=10
ALLURE_REQUEST_TIMEOUT=30
ALLURE_PAGE_SIZE=100
ALLURE_SSL_VERIFY=true
ALLURE_LOG_LEVEL=INFO

# --- Vault Proxy (опц.) ---
# Если задан, ALLURE_TOKEN можно загружать из Vault, оставив его пустым.
# ALLURE_VAULT_URL=

# --- Только если запускаешь alla-server этим же .env (serve.py) ---
# Сервер читает DSN базы знаний и публичный URL отсюда. Обычным
# пользователям скилла, которые ходят на готовый сервер, эти переменные
# не нужны.
# ALLURE_KB_POSTGRES_DSN=postgresql://user:pass@localhost:5432/alla_kb
# ALLURE_REPORTS_POSTGRES=true
# ALLURE_SERVER_EXTERNAL_URL=http://127.0.0.1:8090
