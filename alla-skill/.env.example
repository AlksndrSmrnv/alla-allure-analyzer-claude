# --- TestOps (обязательно) ---
ALLURE_ENDPOINT=https://allure.example.com
ALLURE_TOKEN=
ALLURE_PROJECT_ID=1

# --- PostgreSQL (обязательно — нужен для skill_run, отчётов, KB, feedback) ---
ALLURE_KB_POSTGRES_DSN=postgresql://user:pass@localhost:5432/alla_kb

# --- Push в TestOps выключен по умолчанию ---
# Скрипт push_to_testops.py всё равно требует --confirm, но фоновый
# дефолт оставлен false на случай альтернативных consumers.
ALLURE_PUSH_TO_TESTOPS=false

# --- Отчёты ---
ALLURE_REPORTS_DIR=./reports
ALLURE_REPORT_URL=
ALLURE_REPORT_LINK_NAME=[Alla] HTML-отчёт
ALLURE_SERVER_EXTERNAL_URL=

# --- Тонкие настройки (опц.) ---
ALLURE_CLUSTERING_THRESHOLD=0.60
ALLURE_LOGS_CLUSTERING_WEIGHT=0.15
ALLURE_KB_MIN_SCORE=0.15
ALLURE_KB_MAX_RESULTS=5
ALLURE_LOGS_CONCURRENCY=5
ALLURE_DETAIL_CONCURRENCY=10
ALLURE_REQUEST_TIMEOUT=30
ALLURE_PAGE_SIZE=100
ALLURE_SSL_VERIFY=true
ALLURE_LOG_LEVEL=INFO

# --- Vault Proxy (опц.) ---
# Если задан, ALLURE_TOKEN и ALLURE_KB_POSTGRES_DSN можно загружать
# из Vault, оставив их пустыми в .env.
# ALLURE_VAULT_URL=
